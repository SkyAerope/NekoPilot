{
  "manifest_version": 3,
  "name": "NekoPilot",
  "version": "0.1.1",
  "description": "AI-powered browser automation assistant using Chrome Debugger API",
  "permissions": [
    "debugger",
    "activeTab",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "action": {
    "default_title": "NekoPilot"
  },
  "icons": {},
  "options_page": "options.html"
}
